{
  "manifest_version": 3,
  "name": "Jobsy",
  "version": "1.0",
  "description": "Auto-fill Jobsy",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://seek.com.au/*", "https://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://seek.com.au/*", "https://www.seek.com.au/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["https://seek.com.au/*", "https://www.seek.com.au/*"]
    }
  ]
}
